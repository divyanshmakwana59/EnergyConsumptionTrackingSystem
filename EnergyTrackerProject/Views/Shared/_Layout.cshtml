<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Energy Tracker</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>

        body {
            font-family: 'Inter',sans-serif;
            background: radial-gradient(circle at top,#0f172a,#020617);
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAVBAR */

        .navbar {
            background: rgba(15,23,42,0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .navbar-brand {
            font-weight: 600;
            font-size: 20px;
            color: #38bdf8 !important;
        }

        .nav-link {
            color: #cbd5f5 !important;
            font-weight: 500;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #38bdf8 !important;
            }

        /* MAIN CONTENT */

        .main-content {
            flex: 1;
        }

        /* MODERN CARD */

        .card-modern {
            background: rgba(15,23,42,0.7);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 16px;
            padding: 30px;
            backdrop-filter: blur(8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
            transition: 0.3s;
        }

            .card-modern:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            }

        /* BUTTON */

        .btn-modern {
            background: linear-gradient(135deg,#06b6d4,#3b82f6);
            border: none;
            color: white;
            padding: 8px 18px;
            border-radius: 10px;
        }

            .btn-modern:hover {
                opacity: 0.9;
            }

        /* TABLE */

        table {
            background: #020617;
            border-radius: 10px;
            overflow: hidden;
        }

        thead {
            background: #1e293b;
        }

        tbody tr:hover {
            background: #1e293b;
        }

        /* FOOTER */

        footer {
            text-align: center;
            padding: 15px;
            font-size: 14px;
            background: #020617;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">

            <a class="navbar-brand" href="/Dashboard">Energy Consumption Tracker</a>

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link" href="/Dashboard">Dashboard</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Device">Devices</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Device/Create">Add Device</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Energy/Track">Track Energy</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Energy/Report">Reports</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Tips">Energy Tips</a>
                </li>
            </ul>

        </div>
    </nav>

    <div class="container mt-4 main-content">
        @RenderBody()
    </div>

    <footer>
        ⚡ Energy Consumption Tracking System<br>
        © 2026 Energy Tracker | College Project
    </footer>

</body>
</html>