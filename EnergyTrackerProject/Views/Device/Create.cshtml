@model EnergyTrackerProject.Models.Device

<h2>Add Device</h2>

<form method="post">

	<div class="form-group">
		<label>Device Name</label>
		<input asp-for="DeviceName" class="form-control" />
	</div>

	<div class="form-group">
		<label>Power Rating (Watts)</label>
		<input asp-for="PowerRating" class="form-control" />
	</div>

	<button type="submit" class="btn btn-success">Save</button>

</form>